# ===== 运行环境 =====
ENV=dev
LOG_LEVEL=INFO
LOG_FORMAT=console
LOG_FILE=logs/app.log

# ===== LLM =====
# 支持 OpenAI / 任何兼容 OpenAI 协议的 API
LLM_PROVIDER=openai
LLM_MODEL=deepseek-v4-pro
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60
CHEAP_LLM_MODEL=deepseek-v4-pro

# 快速本地模型使用独立的 OpenAI-compatible 地址；未配置时轻量节点走确定性回退
# LOCAL_LLM_MODEL=qwen2.5:7b
# LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_LLM_API_KEY=local
# LOCAL_LLM_TIMEOUT=15

# 默认只有 SQL 生成可调用远程配置模型，多个任务使用逗号分隔
LLM_REMOTE_TASKS=generate_sql
LLM_ALLOW_REMOTE_FALLBACK=false
# LLM_FALLBACK_CHAIN=gpt-4o,claude-sonnet-4-6

# --- OpenAI ---
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- 其他兼容服务 (如 OneAPI / FastGPT / 本地 vLLM) ---
# OPENAI_BASE_URL=http://localhost:8080/v1
# LLM_MODEL=qwen-72b

# ===== 智能体状态数据库 (PostgreSQL) =====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/data_agent
RUN_MIGRATIONS_ON_STARTUP=true
# 生产环境必须使用只读账号执行用户 SQL
# DATABASE_READONLY_URL=postgresql+asyncpg://reader:password@localhost:5432/analytics

# ===== 向量存储 / ChromaDB =====
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=data_agent_knowledge
# all-MiniLM-L6-v2 模型路径 (不带 onnx 子目录)，必须按本机环境配置
EMBEDDING_MODEL_PATH=

# ===== Redis =====
# 本机直连 Compose Redis；密码需与下方 REDIS_PASSWORD 保持一致
REDIS_URL=redis://:change-me@localhost:6379/0

# ===== 数据源内容缓存 =====
# local: 单机 JSON 持久化；redis: 多实例共享
DATASOURCE_CACHE_BACKEND=local
DATASOURCE_CACHE_DIR=./data/cache/datasource
DATASOURCE_CACHE_TTL_SECONDS=604800
DATASOURCE_CACHE_REDIS_PREFIX=data-agent:datasource-cache

# ===== 多租户与认证（可选） =====
# MULTI_TENANT=true
# JWT_SECRET=change-this-to-random-32-bytes
# ADMIN_API_KEY=change-this-to-random-32-bytes

# ===== API 浏览器安全 =====
# 可信前端 origin，多个值用逗号分隔；空值表示拒绝所有跨域请求，生产禁止使用 *
# CORS_ALLOWED_ORIGINS=https://app.example.com
# 仅生产 HTTPS 响应生效
SECURITY_HSTS_SECONDS=31536000

# ===== 会话上下文（可选） =====
# CONTEXT_MAX_TOKENS=50000
# CONTEXT_HOT_TURNS=5
# CONTEXT_WARM_TURNS=20

# ===== 分析器（可选） =====
# 分析数据投喂 LLM 的最大字符数，超限按比例均匀抽取，默认 50000
# ANALYSIS_DATA_MAX_CHARS=50000

# ===== 限流与资源上限 =====
MAX_QUERIES_PER_HOUR=100
LOGIN_MAX_PER_HOUR=20
REGISTRATION_MAX_PER_HOUR=10
MAX_QUERY_CHARS=8000
MAX_DATASOURCES_PER_QUERY=5
MAX_SCAN_ROWS=10000000
MAX_EXECUTION_TIME=30
MAX_RESULT_ROWS=100000
MAX_STATS_ROWS=500000
MAX_UPLOAD_BYTES=20971520
MAX_UPLOAD_FILES=20
MAX_UPLOAD_TOTAL_BYTES=104857600

# 允许访问私网的可信数据库主机、IP 或 CIDR；空值时仅允许全局可路由地址
# DATASOURCE_HOST_ALLOWLIST=clickhouse.internal,10.20.0.0/16

# ===== LangSmith =====
# LANGSMITH_API_KEY=ls__xxxxxxxx
# LANGSMITH_PROJECT=data-analysis-agent

# ===== MCP =====
MCP_CONFIG_PATH=config/mcp_servers.yaml
# 数据库受管 SSE MCP 精确主机白名单，多个主机用逗号分隔
# MCP_REMOTE_HOST_ALLOWLIST=mcp.example.com,internal-mcp.example.net

# ===== Skills =====
# 内置 Skills 目录（始终加载，不受外部影响）
SKILLS_DIR=skills
# 额外的 Skills 搜索目录，多个路径以分号(;)分隔，上传的 Skill 优先写入第一个额外目录
MANAGED_SKILLS_DIR=data/skills
# EXTRA_SKILLS_DIRS=/data/shared_skills;D:\team_skills

# ===== 凭证加密 =====
# Fernet 主密钥（至少 32 字符），生产环境必须显式配置且源码无默认值
# 非生产环境漏配时只生成进程级临时密钥，重启后无法解密持久化密文
# 生成: python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# CREDENTIAL_ENCRYPTION_KEY=

# ===== 业务文档 =====
METRICS_DOCS_DIR=docs/metrics
# 系统知识只读目录，多个路径用分号分隔；启动时按 checksum 增量扫描
# SYSTEM_KNOWLEDGE_DIRS=docs/system;D:\shared\system_knowledge

# 数据源密码
MYSQL_PASSWORD=your_mysql_password
PG_PASSWORD=your_pg_password
MSSQL_PASSWORD=your_mssql_password

# Docker Compose 服务密码（启动 compose 前必须设置）
REDIS_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me
POSTGRES_PASSWORD=change-me
ORACLE_PASSWORD=change-me
SA_PASSWORD=change-me
CLICKHOUSE_PASSWORD=change-me
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
